PORT=4000

DB_HOST=your-mysql-host
DB_HOST_IP=
DB_PORT=3306
DB_USER=your-mysql-username
DB_PASSWORD=your-mysql-password
DB_SSL=true
DB_SSL_SERVERNAME=
DB_CONNECT_TIMEOUT_MS=30000

JWT_SECRET=replace-with-strong-secret
FRONTEND_ORIGIN=http://localhost:5173

# AI assistant (Hugging Face Inference Providers — chat on the router)
# Create a token at https://huggingface.co/settings/tokens with access to Inference Providers.
HF_API_KEY=your-hugging-face-api-key
# Optional: override chat model (must be routable for your account on Inference Providers).
# If unset, the server tries several defaults with :fastest. Example:
# HF_CHAT_MODEL=Qwen/Qwen2.5-1.5B-Instruct:fastest
# HF_TOKEN and HUGGINGFACEHUB_API_TOKEN are accepted as aliases for HF_API_KEY

